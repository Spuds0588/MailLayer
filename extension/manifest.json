{
  "manifest_version": 3,
  "name": "MailLayer",
  "version": "1.0",
  "description": "Integrated email experience for the web.",
  "icons": {
    "16": "Icons/icon16.png",
    "32": "Icons/icon32.png",
    "48": "Icons/icon48.png",
    "128": "Icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "declarativeNetRequest",
    "activeTab",
    "scripting",
    "identity"
  ],
  "oauth2": {
    "client_id": "1034329801184-789oagdjuvqc43hars9993n7jleo75ke.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.send",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "vendor/quill/quill.min.js",
        "content.js"
      ],
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "MailLayer Settings"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "modal.css",
        "vendor/quill/quill.snow.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
